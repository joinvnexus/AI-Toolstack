# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Database (Supabase PostgreSQL)
# Use pooled URL for app traffic (Session/Transaction pooler).
DATABASE_URL=postgresql://postgres.[project-ref]:password@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1&uselibpqcompat=true
# Use session pooler URL for Prisma migrate/db push.
DIRECT_URL=postgresql://postgres.[project-ref]:password@aws-0-[region].pooler.supabase.com:5432/postgres?sslmode=require&uselibpqcompat=true
# Optional: separate DB for migrate shadow database.
SHADOW_DATABASE_URL=

# Redis (Upstash) - Optional
REDIS_URL=your_redis_url

# Search (Algolia) - Optional
NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=
ALGOLIA_ADMIN_KEY=

# Email (Resend) - Optional
RESEND_API_KEY=

# Storage (Cloudinary) - Optional
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Analytics - Optional
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# Error Tracking - Optional
NEXT_PUBLIC_SENTRY_DSN=
